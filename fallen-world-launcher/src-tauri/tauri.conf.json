{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fallen World Launcher",
  "version": "0.1.0",
  "identifier": "com.fallenworld.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Fallen World Launcher",
        "width": 1400,
        "height": 850,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon-32x32.png",
      "icons/icon-128x128.png",
      "icons/icon-256x256.png",
      "icons/icon-512x512.png",
      "icons/icon.ico"
    ]
  }
}
